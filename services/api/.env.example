# IB Desk API environment (Phase 0). Copy to .env and fill in real values.
# No real secrets belong in this file. These are placeholders only.

# Postgres connection string used by the asyncpg pool.
# Local placeholder value (replace host, user, password, and database):
DATABASE_URL=postgres://ib_desk:CHANGE_ME@localhost:5432/ib_desk
# Supabase example (commented). Replace with your project connection string:
# DATABASE_URL=postgres://postgres:CHANGE_ME@db.YOUR_PROJECT.supabase.co:5432/postgres

# Origin allowed by CORS for GET requests from the web app.
WEB_ORIGIN=http://localhost:3000

# Reported by GET /health as the version field.
APP_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Reserved keys. These are documented here for forward planning only. They are
# NOT settings fields and are NOT used by the service in Phase 0. They are
# ignored if present in the environment. Do not commit real secrets.
# ---------------------------------------------------------------------------
# SUPABASE_URL=                     # reserved, unused in Phase 0
# SUPABASE_SERVICE_ROLE_KEY=        # reserved, unused in Phase 0
# STORAGE_ENDPOINT=                 # reserved, unused in Phase 0
# STORAGE_REGION=                   # reserved, unused in Phase 0
# STORAGE_BUCKET=                   # reserved, unused in Phase 0
# STORAGE_ACCESS_KEY_ID=            # reserved, unused in Phase 0
# STORAGE_SECRET_ACCESS_KEY=        # reserved, unused in Phase 0
# OPENAI_API_KEY=                   # reserved, unused in Phase 0
