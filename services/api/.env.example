# IB Desk API environment. Copy to .env and fill in real values.
# No real secrets belong in this file. These are placeholders only.

# Postgres connection string used by the asyncpg pool.
# Local placeholder value (replace host, user, password, and database):
DATABASE_URL=postgres://ib_desk:CHANGE_ME@localhost:5432/ib_desk
# Supabase example (commented). Replace with your project connection string:
# DATABASE_URL=postgres://postgres:CHANGE_ME@db.YOUR_PROJECT.supabase.co:5432/postgres

# Origin allowed by CORS for GET and POST requests from the web app.
WEB_ORIGIN=http://localhost:3000

# Reported by GET /health as the version field.
APP_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Storage and ingestion (Phase 1). These keys ARE used by the service.
# ---------------------------------------------------------------------------
# Object storage backend for original uploaded files: "local" or "supabase".
# "local" writes to the filesystem and needs no secret; it is the default and
# is what tests and CI use. "supabase" uses Supabase Storage and requires the
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY values below.
STORAGE_BACKEND=local

# Directory used by the local storage backend. Relative paths resolve from the
# service working directory. This directory is gitignored.
STORAGE_LOCAL_PATH=./.local-storage

# Supabase Storage bucket name. Used only when STORAGE_BACKEND=supabase; the local
# filesystem backend ignores this and writes flat keys under STORAGE_LOCAL_PATH.
STORAGE_BUCKET=documents

# Maximum accepted upload size in bytes. Default is 25 MiB (26214400). Uploads
# larger than this are rejected with a file_too_large error before storing.
MAX_UPLOAD_BYTES=26214400

# Scanned-PDF heuristic. When the average extractable characters per page is
# below this value, the document is treated as scanned or unreadable and is
# rejected before any row is written or any byte is stored. A tunable starting
# threshold, not a final value.
SCANNED_MIN_CHARS_PER_PAGE=50

# Supabase Storage credentials, used ONLY when STORAGE_BACKEND=supabase. Leave
# blank for local storage. Do not commit real secrets.
# SUPABASE_URL=                     # used only when STORAGE_BACKEND=supabase
# SUPABASE_SERVICE_ROLE_KEY=        # used only when STORAGE_BACKEND=supabase

# ---------------------------------------------------------------------------
# Reserved keys. Documented here for forward planning only. NOT used by the
# service yet and ignored if present in the environment. Do not commit secrets.
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=                   # reserved, unused until the extraction phase
